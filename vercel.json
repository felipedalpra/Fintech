{
  "crons": [
    {
      "path": "/api/recurrences/process",
      "schedule": "5 6 * * *"
    },
    {
      "path": "/api/alerts/process",
      "schedule": "0 11 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
